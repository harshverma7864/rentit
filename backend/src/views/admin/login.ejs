<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Login — RentPe Admin</title>
  <link rel="stylesheet" href="/admin/public/admin.css">
</head>
<body>
  <div class="login-page">
    <div class="login-card">
      <h1>RentPe</h1>
      <p class="subtitle">Admin Panel</p>
      <% if (typeof error !== 'undefined' && error) { %>
        <div class="alert alert-error"><%= error %></div>
      <% } %>
      <form method="POST" action="/admin/login">
        <div class="form-group">
          <label for="email">Email</label>
          <input type="email" id="email" name="email" required placeholder="admin@rentpe.com">
        </div>
        <div class="form-group">
          <label for="password">Password</label>
          <input type="password" id="password" name="password" required placeholder="••••••••">
        </div>
        <button type="submit" class="btn btn-primary" style="width:100%;justify-content:center;padding:10px;">Sign In</button>
      </form>
    </div>
  </div>
</body>
</html>
