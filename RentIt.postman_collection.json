								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"title\": \"Canon EOS R5 Camera (Updated)\",\n    \"pricePerDay\": 250,\n    \"isAvailable\": true\n}"
