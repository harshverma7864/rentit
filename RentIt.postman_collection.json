		{
			"name": "Bookings",
			"item": [
				{
					"name": "Create Booking",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 201) {",
									"    var jsonData = pm.response.json();",
									"    pm.collectionVariables.set('bookingId', jsonData.booking._id || jsonData._id);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"itemId\": \"{{itemId}}\",\n    \"startDate\": \"2026-04-10T10:00:00.000Z\",\n    \"endDate\": \"2026-04-12T10:00:00.000Z\",\n    \"deliveryOption\": \"pickup\",\n    \"renterNote\": \"I will pick it up at 10 AM.\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/bookings",
							"host": ["{{baseUrl}}"],
							"path": ["api", "bookings"]
						},
						"description": "Create a new booking for an item. Cannot book your own item. Automatically saves the booking ID."
					},
					"response": []
