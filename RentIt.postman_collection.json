				{
					"name": "Create Item",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 201) {",
									"    var jsonData = pm.response.json();",
									"    pm.collectionVariables.set('itemId', jsonData.item._id || jsonData._id);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"title\": \"Canon EOS R5 Camera\",\n    \"description\": \"Professional mirrorless camera, perfect for photo shoots and events.\",\n    \"category\": \"electronics\",\n    \"images\": [\"https://example.com/camera1.jpg\"],\n    \"pricePerHour\": 50,\n    \"pricePerDay\": 200,\n    \"pricePerWeek\": 1000,\n    \"securityDeposit\": 500,\n    \"condition\": \"like_new\",\n    \"location\": {\n        \"coordinates\": [77.209, 28.6139],\n        \"address\": \"Connaught Place, New Delhi\",\n        \"city\": \"New Delhi\"\n    },\n    \"tags\": [\"camera\", \"photography\", \"canon\"],\n    \"rules\": \"Handle with care. Return in original bag.\",\n    \"maxRentalDays\": 30,\n    \"deliveryAvailable\": true,\n    \"deliveryFee\": 100\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/items",
							"host": ["{{baseUrl}}"],
							"path": ["api", "items"]
						},
						"description": "Create a new item listing. Automatically saves the returned item ID."
					},
					"response": []
				},
