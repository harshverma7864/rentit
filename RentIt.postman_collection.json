						"body": {
							"mode": "raw",
							"raw": "{}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/bookings/{{bookingId}}/complete",
							"host": ["{{baseUrl}}"],
							"path": ["api", "bookings", "{{bookingId}}", "complete"]
						},
						"description": "Mark a booking as completed. Booking must be accepted or active."
