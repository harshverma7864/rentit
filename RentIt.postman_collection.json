							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"John Updated\",\n    \"phone\": \"+9876543210\",\n    \"avatar\": \"https://example.com/avatar.jpg\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/auth/profile",
							"host": ["{{baseUrl}}"],
							"path": ["api", "auth", "profile"]
						},
						"description": "Update the authenticated user's profile. All fields are optional."
					},
					"response": []
				},
				{
					"name": "Update Location",
					"request": {
						"method": "PATCH",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"latitude\": 28.6139,\n    \"longitude\": 77.209,\n    \"address\": \"Connaught Place, New Delhi\",\n    \"city\": \"New Delhi\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/auth/location",
							"host": ["{{baseUrl}}"],
							"path": ["api", "auth", "location"]
						},
						"description": "Update the authenticated user's location (stored as GeoJSON)."
					},
					"response": []
				}
			]
		},
