						"body": {
							"mode": "raw",
							"raw": "{\n    \"status\": \"rejected\",\n    \"ownerNote\": \"Sorry, the item is not available on those dates.\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/bookings/{{bookingId}}/respond",
							"host": ["{{baseUrl}}"],
							"path": ["api", "bookings", "{{bookingId}}", "respond"]
						},
						"description": "Reject a pending booking. Only the item owner can respond."
					},
					"response": []
				},
