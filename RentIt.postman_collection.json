					"response": []
				},
				{
					"name": "Accept Booking",
					"request": {
						"method": "PATCH",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"status\": \"accepted\",\n    \"ownerNote\": \"Approved! See you at 10 AM.\",\n    \"estimatedDeliveryTime\": \"30 minutes\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/bookings/{{bookingId}}/respond",
							"host": ["{{baseUrl}}"],
							"path": ["api", "bookings", "{{bookingId}}", "respond"]
						},
						"description": "Accept a pending booking. Only the item owner can respond."
					},
					"response": []
				},
